# pgxllm environment variables
# Copy to .env and fill in your values

# ── Internal DB ───────────────────────────────────────────────
PGXLLM_HOST=localhost
PGXLLM_PORT=5432
PGXLLM_USER=postgres
PGXLLM_PASSWORD=password
PGXLLM_DBNAME=pgxllm

# ── LLM ──────────────────────────────────────────────────────
# Ollama (default)
OLLAMA_BASE_URL=http://localhost:11434

# ── Target DB examples ────────────────────────────────────────
# MYDB_HOST=localhost
# MYDB_PORT=5432
# MYDB_USER=myuser
# MYDB_PASSWORD=

# WH_HOST=warehouse-host
# WH_PORT=5432
# WH_USER=wh_user
# WH_PASSWORD=

# ── Optional ──────────────────────────────────────────────────
# PGXLLM_ROOT=/home/bigfish6/workspace/pgxllm
# PGXLLM_CONFIG=/home/bigfish6/workspace/pgxllm/configs/default.yaml

# Neo4j (if using neo4j graph backend)
# NEO4J_PASSWORD=
